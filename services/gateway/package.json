{
  "name": "@qt/gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "PORT=8083 tsx watch --env-file-if-exists=../../.env src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@neondatabase/serverless": "^0.10.4",
    "@qt/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.13",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "vitest": "^4.1.7"
  }
}
