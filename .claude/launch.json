{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "--env-file-if-exists=.env",
        "services/web/node_modules/next/dist/bin/next",
        "dev",
        "services/web"
      ],
      "autoPort": true
    },
    {
      "name": "data",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["dev:data"],
      "port": 8081
    }
  ]
}
