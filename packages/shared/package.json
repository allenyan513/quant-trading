{
  "name": "@qt/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./db": "./src/db/index.ts",
    "./types": "./src/types.ts",
    "./fmp": "./src/fmp.ts",
    "./edgar": "./src/edgar.ts",
    "./http": "./src/http.ts",
    "./config": "./src/config.ts",
    "./envelope": "./src/envelope.ts",
    "./marketdata": "./src/marketdata/index.ts",
    "./metrics": "./src/metrics.ts",
    "./research": "./src/research.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --env-file-if-exists=../../.env src/db/migrate.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.7",
    "fast-xml-parser": "^5.7.1",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.31.6",
    "vitest": "^4.1.7"
  }
}
