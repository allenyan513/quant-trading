    "./thirteenf-read": "./src/thirteenf-read.ts",
    "./ownership": "./src/ownership.ts",
    "./ownership-read": "./src/ownership-read.ts",
    "./edgar-8k": "./src/edgar-8k.ts",
    "./edgar-8k-read": "./src/edgar-8k-read.ts",
    "./form4": "./src/form4.ts",
    "./form4-read": "./src/form4-read.ts",
    "./edgar-fts": "./src/edgar-fts.ts",
    "./xbrl-frames": "./src/xbrl-frames.ts",
    "./markets": "./src/markets.ts",
    "./market-hours": "./src/market-hours.ts",
    "./earnings-read": "./src/earnings-read.ts",
    "./openfigi": "./src/openfigi.ts",
    "./http": "./src/http.ts",
    "./config": "./src/config.ts",
    "./envelope": "./src/envelope.ts",
    "./marketdata": "./src/marketdata/index.ts",
