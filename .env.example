# Env template. CONVENTION: at most ONE comment line per entry — keep it terse.
# Coding agents editing this file MUST keep comments to a single line each.

# Neon pooled Postgres connection string.
DATABASE_URL=postgresql://user:password@host/db?sslmode=verify-full
# Anthropic API key (alpha signal agent + data triage agent).
ANTHROPIC_API_KEY=sk-ant-...
# Financial Modeling Prep API key.
FMP_API_KEY=...
# Listen port; Cloud Run injects its own, compose sets 8080.
PORT=8080
# Dashboard login password.
DASHBOARD_PASSWORD=change-me
# Random secret for signing dashboard session cookies.
DASHBOARD_SESSION_SECRET=change-me-to-a-long-random-string
# Service-to-service URLs (local dev); compose + Cloud Run override these.
ALPHA_URL=http://localhost:8082
PORTFOLIO_URL=http://localhost:8084
DATA_URL=http://localhost:8081
