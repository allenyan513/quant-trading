# --- Database (Neon serverless Postgres) ---
# Use the POOLED connection string for serverless.
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...
# Model used by the analysis agent's signal loop.
SIGNAL_MODEL=claude-opus-4-8
# Model used by evaluation critique.
CRITIQUE_MODEL=claude-sonnet-4-6

# --- Financial data (FMP) ---
FMP_API_KEY=...
FMP_BASE_URL=https://financialmodelingprep.com/stable

# --- Service-to-service URLs (local docker defaults) ---
# In Cloud Run these become the deployed service URLs.
ANALYSIS_URL=http://analysis:8080
EVALUATION_URL=http://evaluation:8080

# --- Per-service port (Cloud Run injects PORT) ---
PORT=8080
