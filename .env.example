# Env template. CONVENTION: ≤1 comment line per entry — keep it terse.
# Grouped by owning service so a deploy sets only what that service reads
# (least-privilege). Services: data / alpha / portfolio / web. Locally: one shared .env.
# PORT is omitted on purpose — Cloud Run injects it (reserved); dev scripts set it
# per-service (8081/8082/8084); config.port defaults to 8080.

# ---- Shared — every service ----
# Neon pooled Postgres connection string.
DATABASE_URL=postgresql://user:password@host/db?sslmode=verify-full

# ---- web — dashboard + OAuth Authorization Server (lib/auth-server.ts) ----
# Better Auth signing secret — strong random string; required in prod.
BETTER_AUTH_SECRET=change-me-to-a-long-random-string
# Public base URL of the web app (OAuth redirects/metadata); required in prod.
BETTER_AUTH_URL=http://localhost:3001

# ---- data — ingest · news-triage · 13F ---- (IBKR sync moved to portfolio, PR-A)
# AES-256-GCM key for IBKR Flex tokens at rest — used by the PORTFOLIO service now
# (32B base64/64-hex). Gen: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
HOLDINGS_ENC_KEY=change-me-32-byte-base64-key
# Shared secret guarding /jobs/* cron endpoints (data + portfolio); empty = open (dev).
JOB_TOKEN=
# SEC EDGAR User-Agent (13F / EDGAR); has a compliant default — optional.
SEC_USER_AGENT=quant-trading research (you@example.com)
# Financial Modeling Prep API key (marketdata).          also set on: portfolio
FMP_API_KEY=...
# Anthropic API key (data news-triage agent).            also set on: alpha
ANTHROPIC_API_KEY=sk-ant-...

# ---- Backend service-to-service URLs (compose + Cloud Run override these) ----
# data → alpha (deliver events).                         set on: data
ALPHA_URL=http://localhost:8082
# alpha → portfolio (deliver signals).                   set on: alpha
PORTFOLIO_URL=http://localhost:8084
# web forwards writes · alpha fetches reference valuation.  set on: web, alpha
DATA_URL=http://localhost:8081
