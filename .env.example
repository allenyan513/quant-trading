# --- Database (Neon serverless Postgres) ---
# Use the POOLED connection string for serverless.
DATABASE_URL=postgresql://user:password@host/db?sslmode=verify-full

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...
# Model used by the analysis agent's signal loop.
SIGNAL_MODEL=claude-opus-4-8
# Knowledge cutoff of SIGNAL_MODEL — signals on events after this date are
# out-of-sample (look-ahead-safe). Bump together with SIGNAL_MODEL.
MODEL_CUTOFF=2026-01-01

# --- Financial data (FMP) ---
FMP_API_KEY=...
FMP_BASE_URL=https://financialmodelingprep.com/stable

# --- Discovery / universe selection ---
# Min |EPS surprise| (fraction) for the earnings scanner to flag a candidate.
SCAN_EARNINGS_SURPRISE_PCT=0.20
# TTL (days) before a discovery-promoted watchlist entry expires out.
DISCOVERY_TTL_DAYS=30

# --- Service-to-service URLs ---
# Local `pnpm dev` values below. docker-compose overrides these with the
# in-network service hostnames; Cloud Run uses the deployed service URLs.
ANALYSIS_URL=http://localhost:8082
PORTFOLIO_URL=http://localhost:8084
# web → ingestion (candidates promote/dismiss from the dashboard).
INGESTION_URL=http://localhost:8081

# --- Per-service port (Cloud Run injects PORT) ---
# `pnpm dev` assigns each service its own port (8081/8082/8084); this is the fallback.
PORT=8080

# --- Observability ---
# Persist structured logs to the `logs` table (read by apps/dashboard).
# Off by default so unit tests never touch the DB; set `on` for local dev / containers.
LOG_DB=on

# --- Dashboard (apps/dashboard) — keep these server-side, never NEXT_PUBLIC_* ---
DASHBOARD_PASSWORD=change-me
DASHBOARD_SESSION_SECRET=change-me-to-a-long-random-string
