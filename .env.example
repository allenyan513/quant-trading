# Env template. CONVENTION: at most ONE comment line per entry — keep it terse.
# Coding agents editing this file MUST keep comments to a single line each.

# Neon pooled Postgres connection string.
DATABASE_URL=postgresql://user:password@host/db?sslmode=verify-full
# Anthropic API key (alpha signal agent + data triage agent).
ANTHROPIC_API_KEY=sk-ant-...
# Financial Modeling Prep API key.
FMP_API_KEY=...
# SEC EDGAR User-Agent (quarterly financials); has a compliant default, override with your contact.
SEC_USER_AGENT=quant-trading research (you@example.com)
# Listen port; Cloud Run injects its own, compose sets 8080.
PORT=8080
# ---- Better Auth (multi-tenant identity + OAuth AS; services/web/lib/auth-server.ts) ----
# Signing secret — set a strong random string in prod (required).
BETTER_AUTH_SECRET=change-me-to-a-long-random-string
# Public base URL of the web app (used for OAuth redirects/metadata). Local dev default = http://localhost:3001.
BETTER_AUTH_URL=http://localhost:3001
# Service-to-service URLs (local dev); compose + Cloud Run override these.
ALPHA_URL=http://localhost:8082
PORTFOLIO_URL=http://localhost:8084
DATA_URL=http://localhost:8081
# Shared secret for cron/job endpoints (/jobs/*); empty = open (dev).
JOB_TOKEN=
# AES-256-GCM key encrypting IBKR Flex tokens at rest (data service). 32 bytes,
# base64 or 64-hex. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
HOLDINGS_ENC_KEY=change-me-32-byte-base64-key
