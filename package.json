{
  "name": "quant-trading",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.12.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r --if-present test",
    "kill-ports": "lsof -ti:8081,8082,8083,8084,3001 -sTCP:LISTEN 2>/dev/null | xargs kill -9 2>/dev/null; exit 0",
    "predev": "pnpm kill-ports",
    "dev": "pnpm -r --parallel --if-present dev",
    "dev:data": "pnpm --filter @qt/data dev",
    "dev:alpha": "pnpm --filter @qt/alpha dev",
    "dev:portfolio": "pnpm --filter @qt/portfolio dev",
    "dev:gateway": "pnpm --filter @qt/gateway dev",
    "dev:web": "pnpm --filter @qt/web dev",
    "dev:spa": "pnpm --filter @qt/spa dev",
    "db:generate": "pnpm --filter @qt/shared db:generate",
    "db:migrate": "pnpm --filter @qt/shared db:migrate",
    "up": "docker compose up --build",
    "down": "docker compose down"
  },
  "devDependencies": {
    "@types/node": "^22.19.20",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
