{
  "name": "quant-trading",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.12.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r --if-present test",
    "dev": "pnpm -r --parallel --if-present dev",
    "dev:ingestion": "pnpm --filter @qt/ingestion dev",
    "dev:analysis": "pnpm --filter @qt/analysis dev",
    "dev:evaluation": "pnpm --filter @qt/evaluation dev",
    "db:generate": "pnpm --filter @qt/shared db:generate",
    "db:migrate": "pnpm --filter @qt/shared db:migrate",
    "up": "docker compose up --build",
    "down": "docker compose down"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
